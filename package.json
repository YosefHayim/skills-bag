{
  "name": "skills-bag",
  "version": "0.3.0",
  "description": "One-command installer for a personal bag of Claude Code skills and hooks: a context guardrail that forces a graceful /handoff before the window fills, a hands-free autonomous-compact loop (autorun/autostop/autoexit), and a macOS text-to-speech hook. Pure TypeScript, Node-only, no Python.",
  "type": "module",
  "bin": {
    "skills-bag": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "node --import tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "claude",
    "skills",
    "hooks",
    "cli",
    "context-window",
    "handoff",
    "autonomous",
    "agent",
    "ai",
    "developer-tools",
    "macos"
  ],
  "author": "Yosef Hayim Sabag",
  "license": "MIT",
  "homepage": "https://github.com/YosefHayim/skills-bag#readme",
  "bugs": {
    "url": "https://github.com/YosefHayim/skills-bag/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YosefHayim/skills-bag.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
